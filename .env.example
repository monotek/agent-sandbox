# agent-sandbox local configuration
# Copy this file to .env and adjust to your machine.
# .env is gitignored — git pull will never overwrite your settings.
# Variables already exported in your shell take precedence over values here.

# Container image to use.
#AGENT_SANDBOX_IMAGE=ghcr.io/monotek/agent-sandbox:main

# Base directory for all agent configs and credentials (default: ~/agent-sandbox).
# Subdirs .claude, .config/opencode, .copilot, .gemini, .config/gh are auto-mounted when present.
#AGENT_SANDBOX_DIR=/home/yourname/agent-sandbox

# Kubeconfig directory to mount read-only as /home/agent/.kube.
# Not mounted at all when unset.
#AGENT_SANDBOX_KUBE=/home/yourname/agent-sandbox/.kube

# One extra volume mount in Docker/Podman format: /host/path:/container/path[:opts]
# For multiple extra mounts, set AGENT_SANDBOX_MOUNTS in your shell profile
# using the multi-line syntax documented in README.md.
#AGENT_SANDBOX_MOUNTS=/mnt/shared/data:/home/agent/data

# Comma-separated list of host environment variable names to forward into the container.
#AGENT_SANDBOX_ENV=ANTHROPIC_API_KEY,OPENAI_API_KEY,JIRA_API_TOKEN
